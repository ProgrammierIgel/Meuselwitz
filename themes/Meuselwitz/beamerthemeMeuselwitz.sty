\definecolor{test}{HTML}{ff0000}
% --- Titelseite ----------------------------------------------
\setbeamertemplate{title page}{%
  \begin{tikzpicture}[remember picture,overlay]
    \fill[background]
    (current page.south west) rectangle (current page.north east);
    \fill[primary, opacity=0.7]
    (current page.south west) rectangle
    ([yshift=0.024\paperheight]current page.south east);
    \fill[primary, opacity=0.7]
    (current page.north west) rectangle
    ([yshift=-0.020\paperheight]current page.north east);

    % Grosses Logo im Hintergrund rechts (opacity sehr niedrig)
    \node[opacity=0.7,anchor=center]
    at ([xshift=0.28\paperwidth, yshift=-0.1]current page.center){%
      \includegraphics[width=0.4\paperwidth]{logo.png}  %<- echtes Logo
    };
    \fill[primary, opacity=0.4]
      (current page.south west) rectangle
      ([xshift=0.05\paperwidth]current page.north west);
    \node[anchor=west,text width=0.52\paperwidth]
    at ([xshift=0.06\paperwidth,yshift=0.08\paperheight]
    current page.west){%
      \usebeamerfont{title}\usebeamercolor[fg]{title}\inserttitle\\[0.4em]
      \usebeamerfont{subtitle}\usebeamercolor[fg]{subtitle}\insertsubtitle
      \\[1.0em]
      \tikz{\draw[primary,line width=2pt](0,0)--(0.4\paperwidth,0);}
      \\[0.8em]
      \usebeamerfont{author}\usebeamercolor[textcolor]{author}\insertauthor\\[0.25em]
      \usebeamerfont{institute}\usebeamercolor[textcolor]{institute}\insertinstitute
      \\[0.25em]
      \usebeamerfont{date}\usebeamercolor[textcolor]{date}\insertdate%
    };
  \end{tikzpicture}%
}

