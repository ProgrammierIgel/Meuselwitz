\ProvidesPackage{beamerthemeMeuselwitz}
\RequirePackage{tikz}
\RequirePackage{xcolor}

\setbeamertemplate{navigation symbols}{}
\institute{Veit-Ludwig von Seckendorffgymnasium Meuselwitz}

\definecolor{background}{HTML}{10335F} % blau
\definecolor{primary}{HTML}{f2df07} % gelb
%\definecolor{secondary}{model-list}{spec-list}
\definecolor{textcolor}{HTML}{ffffff} % weiß

\setbeamercolor{normal text}{fg=textcolor}
\setbeamercolor{author}{fg=primary}
\setbeamercolor{title}{fg=primary}
\setbeamercolor{frametitle}{fg=primary}
\setbeamercolor{framesubtitle}{fg=primary}
\setbeamercolor{block alertblock exampleblock}{fg=primary}

\setbeamerfont{title}{size=\LARGE, series=\bfseries}
\setbeamerfont{subtitle}{size=\large, series=\normalfont}
\setbeamerfont{author}{size=\normalsize}
\setbeamerfont{frametitle}{size=\large, series=\bfseries}
\setbeamerfont{framesubtitle}{size=\small}
\setbeamerfont{block title}{size=\normalsize, series=\bfseries}
\setbeamerfont{footline}{size=\tiny}
\setbeamercolor{footline2}{bg=primary!85!black, fg=background}

% ================================================================
%  HINTERGRUND MIT LOGO-WASSERZEICHEN
% ================================================================
\setbeamertemplate{background}{%
  \begin{tikzpicture}
    \useasboundingbox (0,0) rectangle (\paperwidth,\paperheight);
    \fill[background] (0,0) rectangle( \paperwidth, \paperheight);
    % Dezenter Streifen links
    %\fill[primary,opacity=0.1] (0,0) rectangle (0.032\paperwidth,\paperheight-0.03);
    % Dezenter Streifen unten
    % \fill[primary!80!black,opacity=0.8]
    % (0,0) rectangle (\paperwidth,0.05\paperheight);
    % Logo rechts unten (sehr transparent)
    \node[opacity=0.2, anchor=base]
    at (0.825\paperwidth, 0.1\paperheight){%
      \includegraphics[width=0.28\paperwidth]{logo.png}%  <- echtes Logo
    };
  \end{tikzpicture}%
}

