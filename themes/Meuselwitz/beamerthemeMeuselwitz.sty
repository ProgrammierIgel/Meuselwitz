% Überschreibung Normaler Block
\renewenvironment{block}[1]{
  \begin{tcolorbox}[
    enhanced, % erweiterte Features wie Transparenz : on
    coltitle=background!95!white, % Titel Textfarbe
    colbacktitle=primary,
    coltext=black,
    colback=primary,
    colframe=primary,
    title=\textbf{#1},
    opacityfill=1,
    opacitytext=1.0,
    arc=1mm,
    boxrule=0.5mm
  ]}{
\end{tcolorbox}}

%Überschreibung Alert block
\renewenvironment{alertblock}[1]{
  \begin{tcolorbox}[
    enhanced, % erweiterte Features wie Transparenz : on
    coltitle=background, % Titel Textfarbe
    colbacktitle=red!80!black,
    coltext=white,
    colback=red!80!black,
    colframe=red!80!black,
    title=\textbf{#1},
    opacityfill=1,
    opacitytext=1.0,
    arc=1mm,
    boxrule=0.5mm
  ]}{
\end{tcolorbox}}


\renewenvironment{exampleblock}[1]{
  \begin{tcolorbox}[
    enhanced, % erweiterte Features wie Transparenz : on
    coltitle=background, % Titel Textfarbe
    colbacktitle=green!60!black,
    coltext=white,
    colback=green!60!black,
    colframe=green!60!black,
    title=\textbf{#1},
    opacityfill=1,
    opacitytext=1.0,
    arc=1mm,
    boxrule=0.5mm
   ]}{
  \end{tcolorbox}}
% Alertblock unterstrichen
\renewcommand{\alert}[1]{{%
    \usebeamercolor[fg]{alerted text}%
    \usebeamerfont{alerted text}%
    \uline{#1}%
}}


