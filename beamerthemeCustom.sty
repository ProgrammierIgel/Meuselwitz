% ============================================================
%  beamerthemeCustom.sty  –  Verwendung: \usetheme{Custom}
% ============================================================
\ProvidesPackage{beamerthemeCustom}[2024/01/01 Custom Beamer Theme]
\RequirePackage{tikz}
\RequirePackage{xcolor}

% --- Farben ---------------------------------------------------
\definecolor{primary}{HTML}{1A3A5C}    % Dunkelblau
\definecolor{secondary}{HTML}{2E86C1}  % Mittelblau
\definecolor{accent}{HTML}{F39C12}     % Gold / Orange
\definecolor{lightgray}{HTML}{F4F6F9}  % Hellgrau
\definecolor{textdark}{HTML}{1C1C1C}   % Fast Schwarz

% --- Farbzuweisungen -----------------------------------------
\setbeamercolor{normal text}{fg=textdark, bg=white}
\setbeamercolor{structure}{fg=primary}
\setbeamercolor{alerted text}{fg=accent}
\setbeamercolor{example text}{fg=secondary}
\setbeamercolor{title}{fg=white}
\setbeamercolor{subtitle}{fg=accent}
\setbeamercolor{author}{fg=white}
\setbeamercolor{date}{fg=white!80!gray}
\setbeamercolor{institute}{fg=white!80!gray}
\setbeamercolor{frametitle}{fg=white, bg=primary}
\setbeamercolor{framesubtitle}{fg=accent}
\setbeamercolor{footline}{fg=white, bg=primary}
\setbeamercolor{block title}{fg=white, bg=secondary}
\setbeamercolor{block body}{fg=textdark, bg=lightgray}
\setbeamercolor{block title alerted}{fg=white, bg=accent}
\setbeamercolor{block body alerted}{fg=textdark, bg=lightgray}
\setbeamercolor{block title example}{fg=white, bg=primary}
\setbeamercolor{block body example}{fg=textdark, bg=lightgray}
\setbeamercolor{item}{fg=secondary}
\setbeamercolor{subitem}{fg=accent}
\setbeamercolor{subsubitem}{fg=primary}

% --- Schriften -----------------------------------------------
\setbeamerfont{title}{size=\LARGE, series=\bfseries}
\setbeamerfont{subtitle}{size=\large, series=\normalfont}
\setbeamerfont{author}{size=\normalsize}
\setbeamerfont{frametitle}{size=\large, series=\bfseries}
\setbeamerfont{framesubtitle}{size=\small}
\setbeamerfont{block title}{size=\normalsize, series=\bfseries}
\setbeamerfont{footline}{size=\tiny}

\setbeamertemplate{navigation symbols}{}

% --- Aufzaehlungszeichen -------------------------------------
\setbeamertemplate{itemize item}{%
  \tikz[baseline=-0.6ex]
    \draw[fill=secondary,draw=none](0,0)circle(0.18em);}
\setbeamertemplate{itemize subitem}{%
  \tikz[baseline=-0.6ex]
    \draw[fill=accent,draw=none](0,0)--(0.30em,0)--(0.15em,0.26em)--cycle;}
\setbeamertemplate{itemize subsubitem}{%
  \tikz[baseline=-0.6ex]
    \draw[fill=primary,draw=none](0,0)rectangle(0.25em,0.25em);}

% ================================================================
%  HINTERGRUND MIT LOGO-WASSERZEICHEN
%  Ersetze den TikZ-Platzhalter durch:
%    \includegraphics[width=0.30\paperwidth]{DEIN_LOGO}
% ================================================================
\setbeamertemplate{background}{%
  \begin{tikzpicture}
    \useasboundingbox (0,0) rectangle (\paperwidth,\paperheight);
    % Dezenter Streifen links
    \fill[primary,opacity=0.06]
      (0,0) rectangle (0.012\paperwidth,\paperheight);
    % Logo rechts unten (sehr transparent)
    \node[opacity=0.07, anchor=south east]
        at (0.98\paperwidth, 0.02\paperheight){%
      \includegraphics[width=0.30\paperwidth]{mein_logo.png}%  <- echtes Logo
      % \tikz{                                                 % <- Platzhalter
      %   \fill[primary]   (0,0) circle (1.8cm);
      %   \fill[secondary] (0,0) circle (1.4cm);
      %   \node[font=\sffamily\bfseries\Large,text=white]at(0,0){LOGO};
      % }%
    };
  \end{tikzpicture}%
}

% --- Titelseite ----------------------------------------------
\setbeamertemplate{title page}{%
  \begin{tikzpicture}[remember picture,overlay]
    \fill[primary]
      (current page.south west) rectangle (current page.north east);
    \fill[secondary]
      (current page.south west) rectangle
      ([yshift=0.012\paperheight]current page.south east);
    \fill[accent]
      ([yshift=0.012\paperheight]current page.south west) rectangle
      ([yshift=0.019\paperheight]current page.south east);
    % Grosses Logo im Hintergrund rechts (opacity sehr niedrig)
    \node[opacity=0.09,anchor=center]
      at ([xshift=0.30\paperwidth]current page.center){%
      \includegraphics[width=0.55\paperwidth]{mein_logo.png}  %<- echtes Logo
      % \tikz{                                                 % <- Platzhalter
      %   \fill[white]             (0,0) circle (3.2cm);
      %   \fill[secondary!60!white](0,0) circle (2.4cm);
      %   \node[font=\sffamily\bfseries\Huge,text=white]at(0,0){LOGO};
      % }%
    };
    \fill[secondary!80!black]
      (current page.south west) rectangle
      ([xshift=0.012\paperwidth]current page.north west);
    % Textblock
    \node[anchor=west,text width=0.75\paperwidth]
      at ([xshift=0.06\paperwidth,yshift=0.08\paperheight]
          current page.west){%
      \usebeamerfont{title}\usebeamercolor[fg]{title}\inserttitle\\[0.4em]
      \usebeamerfont{subtitle}\usebeamercolor[fg]{subtitle}\insertsubtitle
        \\[1.0em]
      \tikz{\draw[accent,line width=1.5pt](0,0)--(0.35\paperwidth,0);}
        \\[0.8em]
      \usebeamerfont{author}\usebeamercolor[fg]{author}\insertauthor\\[0.25em]
      \usebeamerfont{institute}\usebeamercolor[fg]{institute}\insertinstitute
        \\[0.25em]
      \usebeamerfont{date}\usebeamercolor[fg]{date}\insertdate%
    };
  \end{tikzpicture}%
}

% --- Frametitle ----------------------------------------------
\setbeamertemplate{frametitle}{%
  \nointerlineskip
  \begin{beamercolorbox}[wd=\paperwidth,ht=0.60cm,dp=0.20cm,
      leftskip=0.40cm]{frametitle}
    \usebeamerfont{frametitle}\insertframetitle%
    \ifx\insertframesubtitle\empty\else
      \\[-0.1em]\usebeamerfont{framesubtitle}%
      \usebeamercolor[fg]{framesubtitle}\insertframesubtitle%
    \fi
  \end{beamercolorbox}%
  \begin{tikzpicture}
    \draw[accent,line width=1.8pt](0,0)--(\paperwidth,0);
  \end{tikzpicture}%
  \vspace{-6pt}%
}

% --- Fusszeile -----------------------------------------------
\setbeamertemplate{footline}{%
  \begin{beamercolorbox}[wd=\paperwidth,ht=0.42cm,dp=0.16cm]{footline}
    \begin{tikzpicture}[overlay]
      \draw[accent,line width=1.2pt](0,0.58cm)--(\paperwidth,0.58cm);
    \end{tikzpicture}%
    \hspace{0.4cm}%
    \usebeamerfont{footline}%
    \insertshortauthor\hfill
    \insertshorttitle\hfill
    \insertshortdate\hfill
    \insertframenumber\,/\,\inserttotalframenumber
    \hspace{0.4cm}%
  \end{beamercolorbox}%
}

\setbeamertemplate{blocks}[rounded][shadow=false]

% --- Abschnitts-Trennfolie -----------------------------------
\setbeamertemplate{section page}{%
  \begin{tikzpicture}[remember picture,overlay]
    \fill[primary,opacity=0.93]
      (current page.south west) rectangle (current page.north east);
    \draw[accent,line width=2pt]
      ([xshift=-0.25\paperwidth]current page.center)--
      ([xshift= 0.25\paperwidth]current page.center);
    \node[font=\usebeamerfont{title}\bfseries,text=white,anchor=center]
      at ([yshift=0.6em]current page.center){\insertsection};
  \end{tikzpicture}%
}
\AtBeginSection{\frame[plain,noframenumbering]{\sectionpage}}

\endinput
